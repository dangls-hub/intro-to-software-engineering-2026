# ============================================================
# BlueMoon AMS — Biến môi trường cho BACKEND (Spring Boot)
# ============================================================
# Backend đọc các biến này qua placeholder ${...} trong application.yml.
# LƯU Ý: Spring Boot KHÔNG tự đọc file .env. Bạn phải export ra environment
# của process (terminal/IDE Run Configuration) trước khi chạy app.
#
# PowerShell — đặt cho phiên hiện tại rồi chạy backend:
#   $env:MAIL_USERNAME = "ban@gmail.com"
#   $env:MAIL_PASSWORD = "xxxx xxxx xxxx xxxx"
#   cd ams-backend; .\mvnw.cmd spring-boot:run
#
# Đặt cố định ở cấp user (Windows):
#   setx MAIL_PASSWORD "xxxx xxxx xxxx xxxx"   # mở terminal mới để có hiệu lực
#
# Nếu KHÔNG set MAIL_PASSWORD: app vẫn khởi động bình thường, nhưng các email
# (quên mật khẩu, hoá đơn, OTP, nhắc nợ...) sẽ gửi thất bại (chỉ ghi log).
# ============================================================

# Gmail SMTP — dùng App Password 16 ký tự (Google Account → Security → App passwords),
# KHÔNG dùng mật khẩu đăng nhập Gmail thường.
MAIL_USERNAME=bmoonamin@gmail.com
MAIL_PASSWORD=
